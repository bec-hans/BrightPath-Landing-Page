    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BrightPath Learning | Learn skills that get you hired</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --spotify-black: #121212;
            --spotify-dark-grey: #181818;
            --spotify-light-grey: #282828;
            --brightpath-accent: #3d5afe; /* A vibrant, professional blue */
            --brightpath-accent-hover: #536dfe;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--spotify-black);
            color: white;
            scroll-behavior: smooth;
        }

        .spotify-card {
            background-color: var(--spotify-dark-grey);
            transition: background-color 0.3s ease;
        }

        .spotify-card:hover {
            background-color: var(--spotify-light-grey);
        }

        .gradient-text {
            background: linear-gradient(90deg, #fff, #888);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero-gradient {
            background: linear-gradient(180deg, #1e1e1e 0%, #121212 100%);
        }

        .nav-blur {
            backdrop-filter: blur(10px);
            background-color: rgba(0, 0, 0, 0.7);
        }

        .category-card {
            aspect-ratio: 1/1;
            position: relative;
            overflow: hidden;
            border-radius: 8px;
            cursor: pointer;
            transition: transform 0.2s ease, filter 0.2s ease;
        }

        .category-card:hover {
            transform: scale(1.02);
        }

        .category-card.active {
            ring: 3px solid white;
            ring-offset: 2px;
            ring-offset-color: var(--spotify-black);
        }

        .category-card img {
            position: absolute;
            right: -5px; 
            bottom: -5px; 
            width: 110px;
            height: 110px;
            transform: rotate(12deg); 
            object-fit: cover;
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
            border-radius: 4px;
            pointer-events: none;
        }
        
        .category-card img {
            background-color: rgba(255,255,255,0.1);
        }

        /* Detail Panel Animation */
        #category-details {
            grid-column: 1 / -1;
            display: none;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #category-details.active {
            display: block;
            animation: slideDown 0.4s ease-out forwards;
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); max-height: 0; }
            to { opacity: 1; transform: translateY(0); max-height: 500px; }
        }
    </style>
</head>
