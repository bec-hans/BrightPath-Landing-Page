    <script>
        // Smooth scroll implementation
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                const targetId = this.getAttribute('href');
                
                if (targetId.length > 1 && targetId.startsWith('#')) {
                    const targetElement = document.querySelector(targetId);
                    if (targetElement) {
                        e.preventDefault();
                        targetElement.scrollIntoView({
                            behavior: 'smooth'
                        });
                    }
                }
            });
        });

        // Add class on scroll
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('nav');
            if (window.scrollY > 20) {
                nav.classList.add('shadow-2xl');
            } else {
                nav.classList.remove('shadow-2xl');
            }
        });

        // Category Detail Panel Logic
        const categoryData = {
            design: {
                title: "Design & UX Strategy",
                desc: "Master the visual language of the web. Learn UI/UX principles, high-fidelity prototyping, and design systems used by top tech companies. This track covers everything from accessibility to motion design."
            },
            coding: {
                title: "Software Engineering",
                desc: "From Python to React. Build scalable real-world applications and master the logic that powers the modern internet. Dive deep into algorithms, backend architecture, and modern deployment pipelines."
            },
            marketing: {
                title: "Growth & Marketing",
                desc: "Drive growth and build brands that matter. Master SEO, social media strategy, and data-driven performance marketing. Learn how to convert cold leads into loyal brand advocates using advanced analytics."
            },
            business: {
                title: "Business & Leadership",
                desc: "Lead with confidence in the digital age. Learn business strategy, agile operations, and the leadership skills required to scale startups and manage global teams effectively."
            },
            datasci: {
                title: "Data Science & Analysis",
                desc: "Unlock hidden insights from complex datasets. Learn statistics, data visualization, and the analytical tools like R and SQL used by data scientists to drive strategic decision-making."
            },
            aiml: {
                title: "Artificial Intelligence",
                desc: "Build the future of automation. Master neural networks, machine learning algorithms, and generative AI technologies. This path covers ethical AI, large language models, and predictive modeling."
            }
        };

        const categoryCards = document.querySelectorAll('.category-card');
        const detailPanel = document.getElementById('category-details');
        const detailTitle = document.getElementById('detail-title');
        const detailDesc = document.getElementById('detail-desc');
        const closeBtn = document.getElementById('close-details');
        const grid = document.getElementById('category-grid');

        categoryCards.forEach((card, index) => {
            card.addEventListener('click', () => {
                const category = card.dataset.category;
                const data = categoryData[category];
                
                // Clear existing active state
                categoryCards.forEach(c => c.classList.remove('active'));
                card.classList.add('active');

                // Update content
                detailTitle.textContent = data.title;
                detailDesc.textContent = data.desc;

                // Move the detail panel below the current row
                const columns = window.innerWidth >= 1024 ? 6 : (window.innerWidth >= 768 ? 4 : 2);
                const rowIndex = Math.floor(index / columns);
                const targetPosition = (rowIndex + 1) * columns;
                
                // Ensure targetPosition doesn't exceed child count (minus the panel itself)
                const children = Array.from(grid.children).filter(child => child.id !== 'category-details');
                const insertBeforeNode = children[targetPosition] || null;

                // Move and show panel
                grid.insertBefore(detailPanel, insertBeforeNode);
                detailPanel.classList.add('active');
                
                // Smooth scroll to the details if they are below the viewport
                setTimeout(() => {
                    detailPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }, 100);
            });
        });

        closeBtn.addEventListener('click', () => {
            detailPanel.classList.remove('active');
            categoryCards.forEach(c => c.classList.remove('active'));
        });
    </script>
